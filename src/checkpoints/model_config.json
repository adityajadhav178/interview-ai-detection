{
  "bert_model_name": "bert-base-uncased",
  "num_diseases": 4,
  "disease_names": [
    "depression",
    "anxiety",
    "ocd",
    "adhd"
  ],
  "dropout_rate": 0.3,
  "freeze_bert_layers": 8,
  "use_disease_attention": true,
  "hidden_size": 768,
  "num_attention_heads": 8,
  "learning_rate": 2e-05,
  "weight_decay": 0.01,
  "warmup_ratio": 0.1,
  "max_epochs": 5,
  "batch_size": 16,
  "max_length": 256,
  "threshold": 0.5
}